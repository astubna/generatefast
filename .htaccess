<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Vynútenie HTTPS a bez WWW
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^www\.generatefast\.com [NC]
  RewriteRule ^(.*)$ https://generatefast.com/$1 [L,R=301]

  # Štandardné React smerovanie
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>